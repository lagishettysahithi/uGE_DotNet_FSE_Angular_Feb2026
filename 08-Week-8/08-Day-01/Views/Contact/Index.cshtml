@model IEnumerable<WebApplication3.Models.ContactInfo>

<h2>Contact List</h2>

<a asp-action="Create">Create New</a>

<table border="1">
    <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Mobile</th>
        <th>Company</th>
        <th>Department</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.FirstName @item.LastName</td>
            <td>@item.EmailId</td>
            <td>@item.MobileNo</td>
            <td>@item.CompanyName</td>
            <td>@item.DepartmentName</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.ContactId">Details</a> |
                <a asp-action="Edit" asp-route-id="@item.ContactId">Edit</a> |
                <a asp-action="Delete" asp-route-id="@item.ContactId">Delete</a>
            </td>
        </tr>
    }
</table>