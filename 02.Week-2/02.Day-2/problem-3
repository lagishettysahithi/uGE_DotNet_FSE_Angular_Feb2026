<!DOCTYPE html>
<html>
<head>
    <title>problem-3</title>
    <style>
        table {
            border-collapse: collapse;
            margin-top: 15px;
        }
        th, td {
            border: 1px solid black;
            padding: 11px 12px;
            text-align: center;
        }
    </style>
</head>
<body>

    <h2>Employee Data</h2>

    <label>Select Job: </label>
    <select id="jobSelect">
        <option>All Employees</option>
        <option>Manager</option>
        <option>Salesman</option>
        <option>Clerk</option>
    </select>

    <button onclick="showEmployees()">Show Employees</button>

    <div id="tableContainer"></div>

    <script>

        const employees = [
            { id: 101, name: "Sahithi", job: "Manager", salary: 5000 },
            { id: 102, name: "Priya", job: "Salesman", salary: 300 },
            { id: 103, name: "Sai", job: "Clerk", salary: 200 },
            { id: 104, name: "Sneha", job: "Manager", salary: 5500},
            { id: 105, name: "Ammulu", job: "Salesman", salary: 320 }
        ];

        const showEmployees = () => {

            const selectedJob = document.getElementById("jobSelect").value;

            const filteredEmployees = selectedJob === "All Employees"
                ? employees
                : employees.filter(emp => emp.job === selectedJob);

            let tableHTML = `
                <table>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Job</th>
                        <th>Salary</th>
                    </tr>
            `;

            filteredEmployees.forEach(emp => {
                tableHTML += `
                    <tr>
                        <td>${emp.id}</td>
                        <td>${emp.name}</td>
                        <td>${emp.job}</td>
                        <td>${emp.salary}</td>
                    </tr>
                `;
            });

            tableHTML += `</table>`;

            document.getElementById("tableContainer").innerHTML = tableHTML;
        };

        window.showEmployees = showEmployees;

    </script>

</body>
</html>
