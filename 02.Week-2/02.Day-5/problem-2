<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>E-Commerce Landing Page</title>

<!-- Bootstrap 5 CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
  /* Custom Theme */
  :root {
    --bs-primary: #6f42c1;
    --bs-warning: #ff9800;
  }

  .hero {
    background: linear-gradient(135deg, #6f42c1, #9c27b0);
    color: white;
    padding: 80px 0;
  }

  .section-title {
    font-weight: bold;
    margin-bottom: 30px;
  }
</style>
</head>

<body>

<!-- ================= NAVBAR WITH OFFCANVAS ================= -->
<nav class="navbar navbar-dark bg-primary fixed-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="#">ShopZone</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasMenu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Offcanvas Menu -->
    <div class="offcanvas offcanvas-end text-bg-dark" id="offcanvasMenu">
      <div class="offcanvas-header">
        <h5 class="offcanvas-title">Menu</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
      </div>
      <div class="offcanvas-body">
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="#">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="#">Products</a></li>
          <li class="nav-item"><a class="nav-link" href="#">Contact</a></li>
        </ul>
      </div>
    </div>

  </div>
</nav>

<!-- ================= HERO SECTION ================= -->
<section class="hero text-center mt-5">
  <div class="container">
    <h1>Welcome to ShopZone</h1>
    <p>Your One-Stop Online Store</p>
    <button class="btn btn-warning btn-lg">Shop Now</button>
  </div>
</section>

<!-- ================= CAROUSEL ================= -->
<div id="productCarousel" class="carousel slide mt-5 container" data-bs-ride="carousel">

  <div class="carousel-inner">

    <div class="carousel-item active">
      <img src="https://via.placeholder.com/1200x400" class="d-block w-100">
      <div class="carousel-caption">
        <h5>Latest Smartphones</h5>
      </div>
    </div>

    <div class="carousel-item">
      <img src="https://via.placeholder.com/1200x400/aaaaaa" class="d-block w-100">
      <div class="carousel-caption">
        <h5>Fashion Collections</h5>
      </div>
    </div>

  </div>

  <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>

</div>

<!-- ================= PRODUCT SECTION ================= -->
<section class="container mt-5">
  <h2 class="text-center section-title">Featured Products</h2>

  <div class="row">

    <div class="col-sm-6 col-lg-3 mb-4">
      <div class="card">
        <img src="https://via.placeholder.com/300" class="card-img-top">
        <div class="card-body text-center">
          <h5>Product 1</h5>
          <p>$199</p>
          <button class="btn btn-primary btn-sm">Buy Now</button>
        </div>
      </div>
    </div>

    <div class="col-sm-6 col-lg-3 mb-4">
      <div class="card">
        <img src="https://via.placeholder.com/300" class="card-img-top">
        <div class="card-body text-center">
          <h5>Product 2</h5>
          <p>$299</p>
          <button class="btn btn-primary btn-sm">Buy Now</button>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ================= NEWSLETTER ================= -->
<section class="bg-light py-5 mt-5">
  <div class="container text-center">
    <h3>Subscribe to our Newsletter</h3>

    <form class="row justify-content-center mt-3">
      <div class="col-md-4">
        <input type="email" class="form-control" placeholder="Enter your email">
      </div>
      <div class="col-md-2 mt-2 mt-md-0">
        <button class="btn btn-primary w-100">Subscribe</button>
      </div>
    </form>

  </div>
</section>

<!-- ================= FOOTER ================= -->
<footer class="bg-dark text-white text-center p-3">
  © 2026 ShopZone | All Rights Reserved
</footer>

<!-- Bootstrap JS Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
